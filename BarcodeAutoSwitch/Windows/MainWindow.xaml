<Window x:Class="BarcodeAutoSwitch.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wpf="clr-namespace:CefSharp.Wpf;assembly=CefSharp.Wpf"
        xmlns:behaviours="clr-namespace:BarcodeAutoSwitch.UI.Behaviours"
        xmlns:converters="clr-namespace:BarcodeAutoSwitch.UI.Converters"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        Title="BarcodeAutoSwitch"
        Icon="/Resources/icon.ico"
        WindowState="Maximized">

    <Window.Resources>
        <converters:StringToColorBrushConverter x:Key="StringToColorBrushConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Navigation bar -->
        <Grid Grid.Row="0">
            <Grid.Resources>
                <Style TargetType="Button">  <Setter Property="Margin" Value="2,5"/></Style>
                <Style TargetType="TextBox"> <Setter Property="Margin" Value="2,5"/></Style>
            </Grid.Resources>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0" Text="{Binding Address, ElementName=Browser}" FontSize="12"
                     BorderBrush="Gray" BorderThickness="1" IsEnabled="False">
                <i:Interaction.Behaviors>
                    <behaviours:TextBoxBindingUpdateOnEnterBehaviour/>
                </i:Interaction.Behaviors>
            </TextBox>

            <Button Grid.Column="1" Content="Cambia porta COM"
                    Command="{Binding ChangeCOMPortCommand}" Width="Auto"/>
        </Grid>

        <!-- Fallback: no valid COM port -->
        <Grid Name="BackgroundGrid" Grid.Row="1" Panel.ZIndex="0"
              Visibility="{Binding IsBrowserVisible, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock FontSize="30" TextAlignment="Center" Text="Porta COM non valida." Margin="0,0,0,20"/>
                <TextBlock FontSize="20" TextAlignment="Center"
                           Text="Selezionare una porta COM valida utilizzando l'apposita funzione." Margin="0,0,0,20"/>
                <Button Content="Cambia porta COM" Command="{Binding ChangeCOMPortCommand}"
                        Width="200" Height="50" FontSize="18"/>
            </StackPanel>
        </Grid>

        <!-- Browser -->
        <Grid Grid.Row="1" Panel.ZIndex="1"
              Visibility="{Binding IsBrowserVisible, Converter={StaticResource BoolToVisibility}}">
            <Border BorderBrush="Gray" BorderThickness="0,1">
                <wpf:ChromiumWebBrowser x:Name="Browser" Address="about:blank">
                    <i:Interaction.Behaviors>
                        <behaviours:HoverLinkBehaviour x:Name="HoverLinkBehaviour"/>
                    </i:Interaction.Behaviors>
                </wpf:ChromiumWebBrowser>
            </Border>
        </Grid>

        <!-- Progress bar -->
        <ProgressBar IsIndeterminate="{Binding IsLoading, ElementName=Browser}"
                     HorizontalAlignment="Stretch" VerticalAlignment="Top"
                     Height="2" Grid.Row="2" Width="Auto" BorderThickness="0"
                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}, ElementName=Browser}"/>

        <!-- Status bar -->
        <StatusBar Grid.Row="2" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
            <StatusBar.ItemsPanel>
                <ItemsPanelTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                    </Grid>
                </ItemsPanelTemplate>
            </StatusBar.ItemsPanel>

            <StatusBarItem Grid.Column="0">
                <Button Content="Show Console" Width="100"
                        Command="{Binding ShowHideConsoleCommand}"/>
            </StatusBarItem>

            <StatusBarItem Grid.Column="1" HorizontalAlignment="Right">
                <Button Width="100" Content="{Binding EnableDisableButtonText}"
                        Command="{Binding ToggleAutoSwitchCommand}"/>
            </StatusBarItem>

            <StatusBarItem Grid.Column="2"
                           Background="{Binding StatusColor, Converter={StaticResource StringToColorBrushConverter}}"
                           HorizontalAlignment="Right">
                <TextBlock Text="{Binding StatusText}" FontWeight="Bold" FontSize="15"
                           Height="18" Width="150" TextAlignment="Center"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
