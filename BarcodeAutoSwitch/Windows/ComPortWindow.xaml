<Window x:Class="BarcodeAutoSwitch.Windows.DeviceManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestisci dispositivi" Height="340" Width="480"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Label Grid.Row="0" Content="Dispositivi configurati:" FontWeight="SemiBold" Margin="0,0,0,4"/>

        <!-- Device list -->
        <Border Grid.Row="1" BorderBrush="#CCCCCC" BorderThickness="1" Margin="0,0,0,10">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="DeviceList" ItemsSource="{Binding Devices}" Margin="4">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Status dot: green = available at last startup, gray = not found -->
                                <TextBlock Grid.Column="0" Text="●" VerticalAlignment="Center" FontSize="10">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#999999"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsAvailable}" Value="True">
                                                    <Setter Property="Foreground" Value="#22AA44"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <StackPanel Grid.Column="1" Margin="4,0">
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding DeviceId}" FontSize="10" Foreground="Gray"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>

                                <Button Grid.Column="2" Content="✕" Width="24" Height="24"
                                        VerticalAlignment="Center" Padding="0"
                                        Tag="{Binding}" Click="OnRemoveDevice"
                                        ToolTip="Rimuovi questo dispositivo"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Add button -->
        <Button Grid.Row="2" Content="+ Aggiungi dispositivo"
                HorizontalAlignment="Left" Padding="8,4" Margin="0,0,0,10"
                Click="OnAddDevice"/>

        <!-- Close button -->
        <Button Grid.Row="3" Content="Chiudi"
                HorizontalAlignment="Right" Width="80"
                Click="OnClose"/>
    </Grid>
</Window>
