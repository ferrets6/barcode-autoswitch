<Window x:Class="BarcodeAutoSwitch.Windows.ComPortWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:BarcodeAutoSwitch.UI.Converters"
        Title="Selezione Porta COM" Height="295" Width="350"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <converters:PortTestResultToImageConverter x:Key="PortTestResultToImage"/>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Label Grid.Row="0" Content="Seleziona porta COM" FontWeight="SemiBold" Margin="0,0,0,4"/>

        <ComboBox Grid.Row="1" ItemsSource="{Binding AvailablePorts}"
                  SelectedItem="{Binding SelectedPort}"
                  Height="26" Margin="0,0,0,12"/>

        <TextBlock Grid.Row="2" TextWrapping="WrapWithOverflow" TextAlignment="Justify"
                   Margin="0,0,0,12"
                   Text="Per testare la porta selezionata, scannerizzare il codice sottostante con il lettore barcode."/>

        <Image Grid.Row="3" HorizontalAlignment="Left" VerticalAlignment="Top"
               Source="{Binding TestResult, Converter={StaticResource PortTestResultToImage}}"/>
    </Grid>
</Window>
