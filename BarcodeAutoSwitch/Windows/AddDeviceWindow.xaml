<Window x:Class="BarcodeAutoSwitch.Windows.AddDeviceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Aggiungi dispositivo" Height="460" Width="420"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner">

    <DockPanel Margin="12">

        <!-- Bottom buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Annulla" Width="80" Margin="0,0,8,0" Click="OnCancel"/>
            <Button Content="Aggiungi" Width="80"
                    IsEnabled="{Binding IsAddEnabled}"
                    Click="OnAdd"/>
        </StackPanel>

        <!-- Main content -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Label Grid.Row="0" Content="Seleziona dispositivo:" FontWeight="SemiBold" Margin="0,0,0,2"/>

            <ComboBox Grid.Row="1"
                      ItemsSource="{Binding AvailableDevices}"
                      SelectedItem="{Binding SelectedDevice}"
                      Height="26" Margin="0,0,0,2">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Type}" Foreground="Gray"
                                       FontSize="11" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <!-- Hardware ID / device path — small reference label -->
            <TextBlock Grid.Row="2" Text="{Binding SelectedDevice.HardwareId}"
                       Foreground="Gray" FontSize="10" Margin="2,0,0,8"
                       TextTrimming="CharacterEllipsis"/>

            <!-- Per-device options -->
            <StackPanel Grid.Row="3" Margin="2,0,0,12">
                <CheckBox IsChecked="{Binding HasIdentifierPrefix}"
                          Content="Prefisso identificatore (lettori seriali COM)"
                          Margin="0,0,0,4"/>
                <CheckBox IsChecked="{Binding TrimTrailingZeros}"
                          Content="Taglia zeri in coda (solo codice di attivazione)"/>
            </StackPanel>

            <Separator Grid.Row="4" Margin="0,0,0,10"/>

            <TextBlock Grid.Row="5" TextWrapping="Wrap" Margin="0,0,0,8">
                Scansiona il codice di test con il dispositivo selezionato:
            </TextBlock>

            <!-- Static test-barcode image -->
            <Image Grid.Row="6" HorizontalAlignment="Left" VerticalAlignment="Top"
                   Source="/Resources/checkPortBarcode.gif" MaxHeight="110" Margin="0,0,0,8"/>

            <!-- Test result as coloured text -->
            <TextBlock Grid.Row="7"
                       Text="{Binding TestResultText}"
                       Foreground="{Binding TestResultColor}"
                       FontWeight="SemiBold" FontSize="13"
                       TextWrapping="Wrap"/>
        </Grid>
    </DockPanel>
</Window>
