<Window x:Class="BarcodeAutoSwitch.ComPortWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BarcodeAutoSwitch"
        mc:Ignorable="d"
        Title="ComPortWindow" Height="294.667" Width="347.467">
    <Grid Margin="0,0,3.8,2.8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <ComboBox x:Name="portComListComboBox" HorizontalAlignment="Left" Height="26" Margin="74,43,0,0" VerticalAlignment="Top" Width="195" SelectionChanged="portComListComboBox_SelectionChanged"/>
        <Label x:Name="label" Content="Seleziona porta COM" HorizontalAlignment="Left" Height="28" Margin="74,10,0,0" VerticalAlignment="Top" Width="194"/>
        <TextBlock x:Name="textBlock" HorizontalAlignment="Left" Margin="10,74,0,0" TextWrapping="WrapWithOverflow" TextAlignment="Justify" VerticalAlignment="Top" Height="48" Width="317" Text="Per testare la porta selezionata, scannerizzare il codice sottostante con il lettore barcode."/>
        <Image x:Name="checkPortImage" HorizontalAlignment="Left" Height="Auto" Margin="10,127,0,0" VerticalAlignment="Top" Width="Auto"/>

    </Grid>
</Window>
